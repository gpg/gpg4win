#! /bin/sh
patch -p1 -l -f $* < $0
exit $?

From ff8b41949aced22770b5fd5871594c159e9d0db3 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Ingo=20Kl=C3=B6cker?= <dev@ingo-kloecker.de>
Date: Tue, 3 Mar 2026 10:26:20 +0100
Subject: [PATCH 1/2] Avoid creation of not already existing registry keys

QSettings's fileName constructor creates the file or, with Windows
native format, the registry key if it doesn't already exist. Hence,
we create the QSettings object with the known-to-exist SOFTWARE key
and set the group to the desired path.
---
 src/core/kconfig.cpp      | 4 +---
 src/core/registry_win.cpp | 5 +++--
 2 files changed, 4 insertions(+), 5 deletions(-)

diff --git a/src/core/kconfig.cpp b/src/core/kconfig.cpp
index 44adcf6c..840d4fe9 100644
--- a/src/core/kconfig.cpp
+++ b/src/core/kconfig.cpp
@@ -775,9 +775,7 @@ void KConfigPrivate::parseWindowsDefaults()
     if (fileName.isEmpty() || QCoreApplication::organizationName().isEmpty()) {
         return;
     }
-    auto registryKey =
-        QStringLiteral("SOFTWARE\\%1\\%2")
-            .arg(QCoreApplication::organizationName(), fileName.endsWith(QStringLiteral("rc")) ? fileName.left(fileName.length() - 2) : fileName);
+    const QString registryKey = QCoreApplication::organizationName() + u'/' + (fileName.endsWith(QStringLiteral("rc")) ? fileName.chopped(2) : fileName);
     WindowsRegistry::parse(registryKey, entryMap);
 }
 #endif
diff --git a/src/core/registry_win.cpp b/src/core/registry_win.cpp
index 451ad8dc..dac5c0d1 100644
--- a/src/core/registry_win.cpp
+++ b/src/core/registry_win.cpp
@@ -61,8 +61,9 @@ static void parseRegSubkeys(const QString &baseGroup, QSettings &settings, KEntr

 static void parseRegistry(const QString &regKey, KEntryMap &entryMap, Registry registry)
 {
-    QString registryPath = (registry == HKCU ? QStringLiteral("HKEY_CURRENT_USER\\") : QStringLiteral("HKEY_LOCAL_MACHINE\\")) + regKey;
-    QSettings settings(registryPath, QSettings::NativeFormat);
+    QSettings settings((registry == HKCU ? QStringLiteral("HKEY_CURRENT_USER\\SOFTWARE") : QStringLiteral("HKEY_LOCAL_MACHINE\\SOFTWARE")),
+                       QSettings::NativeFormat);
+    settings.beginGroup(regKey);
     parseRegSubkeys(QStringLiteral("<default>"), settings, entryMap, false);
 }

